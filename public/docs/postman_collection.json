    "description": "Postman collection for the AFIFI Backend REST API, generated from public/docs/openapi.yaml. Groups match the Swagger tags: Auth, Catalog, Cart, Wishlist, Address, Checkout, Orders, Payments, Returns, Coupons, Campaigns, CMS, Settings, Admin.\n\nAuthentication: obtain a token from Auth > Register or Auth > Login, then set the collection variable `token` to that value (or use the response's test script if you add one). Protected requests send `Authorization: Bearer {{token}}` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
